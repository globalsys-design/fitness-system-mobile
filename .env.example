# Database (Neon - https://neon.tech)
DATABASE_URL=              # postgresql://user:pass@host/db?sslmode=require

# Auth.js v5
AUTH_SECRET=               # openssl rand -base64 32
AUTH_URL=                  # https://your-app.vercel.app (production URL)
AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=            # Google Cloud Console → APIs & Services → Credentials
AUTH_GOOGLE_SECRET=        # Google Cloud Console → OAuth Client Secret
AUTH_RESEND_KEY=           # Resend API Key (para magic links)

# Stripe
STRIPE_SECRET_KEY=         # Stripe Dashboard → Developers → API Keys
STRIPE_WEBHOOK_SECRET=     # Stripe Dashboard → Developers → Webhooks → Signing Secret
STRIPE_PRICE_ID_PRO=       # Stripe Dashboard → Products → Price ID (price_xxx)

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO=  # Same as STRIPE_PRICE_ID_PRO

# Resend (emails transacionais)
RESEND_API_KEY=            # Resend Dashboard → API Keys
